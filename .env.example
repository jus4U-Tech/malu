# ─────────────────────────────────────────────
# BBB da Malu — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ─────────────────────────────────────────────

NODE_ENV=development   # development | production

# ── App ──────────────────────────────────────
APP_NAME="BBB da Malu"
APP_URL="http://localhost:3000"

# ── Banco de dados ────────────────────────────
# Dev: PostgreSQL local via Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bbb_malu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Prisma usa DATABASE_URL — trocada automaticamente por env
# Dev:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bbb_malu"
# Prod (Supabase Transaction Pooler — porta 6543):
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ── Supabase (produção) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Vercel (deploy via CLI / GitHub Actions) ──
VERCEL_TOKEN=xxxxxxxxxxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxx
VERCEL_ORG_ID=team_xxxxxxx

# ── GitHub ────────────────────────────────────
GITHUB_REPO=seunome/bbb-da-malu
GITHUB_TOKEN=ghp_xxxxxxxx

# ── Anthropic (IA) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
